                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"operation\": {\n        \"shop_process_id\": 103,\n        \"response_code\": \"00\",\n        \"response_description\": \"Aprobado\",\n        \"amount\": 25000,\n        \"currency\": \"PYG\",\n        \"ticket_number\": \"123456\",\n        \"authorization_number\": \"654321\"\n    }\n}"
