# Variables de Entorno — Bancard vPOS Backend

# ============================================================
# SERVIDOR
# ============================================================
PORT=3000
NODE_ENV=staging

# ============================================================
# CREDENCIALES BANCARD
# Obtener en: https://comercios.bancard.com.py
# ============================================================
BANCARD_PUBLIC_KEY=your_public_key_here
BANCARD_PRIVATE_KEY=your_private_key_here

# ============================================================
# URLS DE BANCARD
# ============================================================
BANCARD_STAGING_URL=https://vpos.infonet.com.py:8888
BANCARD_PRODUCTION_URL=https://vpos.infonet.com.py

# ============================================================
# URL DE TU APLICACION (para callbacks)
# ============================================================
APP_URL=http://localhost:3000

# ============================================================
# URLS DE RETORNO AL CLIENTE (configurar con tu frontend)
# ============================================================
RETURN_URL=http://localhost:3000/payment/success
CANCEL_URL=http://localhost:3000/payment/cancel
